---
interface Props {
  title: string;
  icon: any;
  id?: string;
}

const { title, icon: Icon, id } = Astro.props;
---

<div class="mb-4 flex items-center gap-2 text-sm font-semibold text-zinc-100">
  <Icon className="size-4 text-emerald-300" aria-hidden="true" />
  {id ? <h2 id={id}>{title}</h2> : <h2>{title}</h2>}
</div>
