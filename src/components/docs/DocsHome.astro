---
import { Card, CardGrid, Code } from '@astrojs/starlight/components';
import { FaGithub } from 'react-icons/fa6';
import { LuArrowRight } from 'react-icons/lu';
import {
  architectureFlow,
  architectureNotes,
  gettingStartedLinks,
  guarantees,
  heroExample,
  heroProperties,
  persistenceFlow,
  productionReadiness,
  stabilityLinks,
  useCases,
  whatVaylixIs,
  whatVaylixIsNot,
} from './data/home';
---

<div class="not-prose max-w-full space-y-8 overflow-x-clip">
  <section class="rounded-2xl border border-white/10 bg-zinc-950/80 p-6 ring-1 ring-white/5 sm:p-8">
    <div class="grid gap-8 xl:grid-cols-[minmax(0,1.2fr)_minmax(20rem,0.8fr)]">
      <div class="space-y-5">
        <div class="text-[0.72rem] font-medium uppercase tracking-[0.22em] text-zinc-500">
          Vaylix
        </div>
        <div class="space-y-3">
          <h1 class="text-3xl font-semibold tracking-tight text-white sm:text-5xl">
            A secure, consensus-backed key-value database for operational state.
          </h1>
          <p class="max-w-3xl text-base leading-7 text-zinc-300">
            Technical documentation for operators and integrators working with the current Vaylix
            release line.
          </p>
        </div>
        <ul class="grid gap-2 text-sm leading-6 text-zinc-300 sm:grid-cols-2">
          {heroProperties.map((item) => (
            <li class="flex gap-3">
              <span class="mt-2 size-1.5 shrink-0 rounded-full bg-emerald-300" aria-hidden="true"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
        <nav aria-label="Primary entry points" class="flex flex-wrap gap-3">
          <a
            href="/getting-started/install-and-build/"
            class="inline-flex items-center gap-2 rounded-xl border border-emerald-400/20 bg-emerald-400 px-4 py-2.5 text-sm font-semibold text-zinc-950 transition hover:bg-emerald-300"
          >
            Getting started
            <LuArrowRight className="size-4" aria-hidden="true" />
          </a>
          <a
            href="/reference/commands/"
            class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-zinc-900 px-4 py-2.5 text-sm font-semibold text-zinc-100 transition hover:border-emerald-400/30"
          >
            Command reference
          </a>
          <a
            href="https://github.com/vaylix/vaylix/releases/tag/v0.8.0"
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-2 rounded-xl border border-white/10 px-4 py-2.5 text-sm font-semibold text-zinc-300 transition hover:border-emerald-400/30 hover:text-white"
          >
            <FaGithub className="size-4" aria-hidden="true" />
            Release v0.8.0
          </a>
        </nav>
      </div>

      <div class="rounded-2xl border border-white/10 bg-black/30 p-5">
        <h2 class="mb-4 text-sm font-semibold text-zinc-100">Minimal example</h2>
        <div class="overflow-x-auto rounded-xl border border-white/10 bg-black/50">
          <Code code={heroExample} lang="bash" />
        </div>
      </div>
    </div>
  </section>

  <section>
    <CardGrid>
      <Card title="What Vaylix Is">
        <ul class="space-y-3 text-sm leading-6 text-zinc-300">
          {whatVaylixIs.map((item) => (
            <li class="flex gap-3">
              <span class="mt-2 size-1.5 shrink-0 rounded-full bg-emerald-300" aria-hidden="true"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
        <div class="mt-5 border-t border-white/10 pt-5">
          <h3 class="mb-3 text-sm font-semibold uppercase tracking-[0.16em] text-zinc-500">Use cases</h3>
          <ul class="space-y-2 text-sm text-zinc-300">
            {useCases.map((item) => (
              <li class="flex gap-3">
                <span class="mt-2 size-1.5 shrink-0 rounded-full bg-zinc-500" aria-hidden="true"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </Card>

      <Card title="What Vaylix Is Not">
        <ul class="space-y-3 text-sm leading-6 text-zinc-300">
          {whatVaylixIsNot.map((item) => (
            <li class="flex gap-3">
              <span class="mt-2 size-1.5 shrink-0 rounded-full bg-zinc-500" aria-hidden="true"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </Card>
    </CardGrid>
  </section>

  <section class="rounded-2xl border border-white/10 bg-zinc-950/75 p-6 ring-1 ring-white/5">
    <h2 class="mb-4 text-lg font-semibold text-white">Architecture Overview</h2>
    <div class="grid gap-6 xl:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
      <div class="space-y-4">
        <div class="rounded-xl border border-white/10 bg-black/40 p-4 font-mono text-sm text-zinc-200">
          <div>{architectureFlow.join(' → ')}</div>
          <div class="mt-2 text-zinc-500">{persistenceFlow.join(' → ')}</div>
        </div>
      </div>
      <ul class="space-y-3 text-sm leading-6 text-zinc-300">
        {architectureNotes.map((item) => (
          <li class="flex gap-3">
            <span class="mt-2 size-1.5 shrink-0 rounded-full bg-emerald-300" aria-hidden="true"></span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section>
    <CardGrid>
      <Card title="Guarantees">
        <ul class="space-y-3 text-sm leading-6 text-zinc-300">
          {guarantees.map((item) => (
            <li class="flex gap-3">
              <span class="mt-2 size-1.5 shrink-0 rounded-full bg-emerald-300" aria-hidden="true"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </Card>

      <Card title="Production Readiness">
        <ul class="space-y-3 text-sm leading-6 text-zinc-300">
          {productionReadiness.map((item) => (
            <li>
              <a class="text-zinc-100 hover:text-emerald-300" href={item.href}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </Card>
    </CardGrid>
  </section>

  <section>
    <CardGrid>
      <Card title="Getting Started">
        <ul class="space-y-3 text-sm leading-6 text-zinc-300">
          {gettingStartedLinks.map((item) => (
            <li>
              <a class="text-zinc-100 hover:text-emerald-300" href={item.href}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
        <p class="mt-5 text-sm text-zinc-500">
          The full documentation set covers runtime flags, protocol behavior, persistence, security,
          and HA operations.
        </p>
      </Card>

      <Card title="Stability and Compatibility">
        <ul class="space-y-3 text-sm leading-6 text-zinc-300">
          {stabilityLinks.map((item) => (
            <li>
              <a class="text-zinc-100 hover:text-emerald-300" href={item.href}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </Card>
    </CardGrid>
  </section>
</div>
