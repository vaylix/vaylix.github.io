---
import { Card, CardGrid, Code } from '@astrojs/starlight/components';
import { FaGithub } from 'react-icons/fa6';
import { LuArrowRight } from 'react-icons/lu';
import {
architectureLayers,
architectureNotes,
architecturePersistence,
compatibilityLinks,
currentLine,
guaranteeFacts,
heroExample,
heroProperties,
landingCliReplExample,
landingDockerExample,
landingSdkExample,
nonGuarantees,
notForWorkloads,
readinessLinks,
suitableWorkloads
} from './data/home';
---

<div class="not-prose max-w-full space-y-8 overflow-x-hidden">
  <section class="overflow-hidden rounded-2xl border border-white/10 bg-zinc-950/80 p-4 ring-1 ring-white/5 sm:p-6 lg:p-8">
    <div class="grid min-w-0 gap-6 xl:grid-cols-[minmax(0,1.15fr)_minmax(18rem,0.85fr)]">
      <div class="min-w-0 space-y-5">
        <div class="space-y-2">
          <div class="text-[0.72rem] font-medium uppercase tracking-[0.22em] text-zinc-500">
            Vaylix
          </div>
          <h1 class="text-3xl font-semibold tracking-tight text-white sm:text-5xl">
            A secure, consensus-backed key-value database for operational state.
          </h1>
          <p class="max-w-3xl text-sm leading-7 text-zinc-300 sm:text-base">
            Vaylix is a key-value store built for operational state that must survive crashes. It
            fsyncs every acknowledged write and, in HA mode, commits writes to a quorum before
            returning success.
          </p>
          <p class="text-sm leading-6 text-zinc-500">
            Current line: server {currentLine.server}, TypeScript SDK {currentLine.sdk}. Pre-1.0
            means the storage format and compatibility policy are documented explicitly instead of
            implied.
          </p>
        </div>

        <ul class="grid min-w-0 gap-2 text-sm leading-6 text-zinc-300">
          {heroProperties.map((item) => (
            <li class="flex min-w-0 gap-3">
              <span class="mt-2 size-1.5 shrink-0 rounded-full bg-emerald-300" aria-hidden="true"></span>
              <span class="min-w-0">{item}</span>
            </li>
          ))}
        </ul>

        <nav aria-label="Primary entry points" class="grid gap-3 sm:flex sm:flex-wrap">
          <a
            href="/getting-started/"
            class="inline-flex w-full items-center justify-center gap-2 rounded-xl border border-emerald-400/20 bg-emerald-400 px-4 py-3 text-sm font-semibold text-zinc-950 transition hover:bg-emerald-300 sm:w-auto"
          >
            Getting started
            <LuArrowRight className="size-4" aria-hidden="true" />
          </a>
          <a
            href="/reference/commands/"
            class="inline-flex w-full items-center justify-center gap-2 rounded-xl border border-white/10 bg-zinc-900 px-4 py-3 text-sm font-semibold text-zinc-100 transition hover:border-emerald-400/30 sm:w-auto"
          >
            Command reference
          </a>
          <a
            href="https://github.com/vaylix/vaylix/releases/tag/v0.9.0"
            target="_blank"
            rel="noreferrer"
            class="inline-flex w-full items-center justify-center gap-2 rounded-xl border border-white/10 px-4 py-3 text-sm font-semibold text-zinc-300 transition hover:border-emerald-400/30 hover:text-white sm:w-auto"
          >
            <FaGithub className="size-4" aria-hidden="true" />
            Release {currentLine.server}
          </a>
        </nav>
      </div>

      <div class="min-w-0 rounded-2xl border border-white/10 bg-black/30 p-4 sm:p-5">
        <h2 class="mb-4 text-sm font-semibold text-zinc-100">Minimal example</h2>
        <div class="max-w-full overflow-x-auto rounded-xl border border-white/10 bg-black/50">
          <Code code={heroExample} lang="bash" />
        </div>
      </div>
    </div>
  </section>

  <section class="space-y-6">
    <div class="space-y-2">
      <h2 class="text-2xl font-semibold text-white">What Vaylix is</h2>
      <p class="text-sm leading-7 text-zinc-300 sm:text-base">
        Vaylix is a durable key-value database for control-plane and operational state. It keeps
        transport, server policy, and storage separated so write durability, failure handling, and
        access control stay explicit instead of implicit.
      </p>
    </div>

    <CardGrid>
      <Card title="Who it is for">
        <ul class="space-y-3 text-sm leading-6 text-zinc-300">
          {suitableWorkloads.map((item) => (
            <li class="flex gap-3">
              <span class="mt-2 size-1.5 shrink-0 rounded-full bg-emerald-300" aria-hidden="true"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </Card>

      <Card title="What it is not for">
        <ul class="space-y-3 text-sm leading-6 text-zinc-300">
          {notForWorkloads.map((item) => (
            <li class="flex gap-3">
              <span class="mt-2 size-1.5 shrink-0 rounded-full bg-zinc-500" aria-hidden="true"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </Card>
    </CardGrid>
  </section>

  <section>
    <CardGrid>
      <Card title="What it guarantees">
        <ul class="space-y-3 text-sm leading-6 text-zinc-300">
          {guaranteeFacts.map((item) => (
            <li class="flex gap-3">
              <span class="mt-2 size-1.5 shrink-0 rounded-full bg-emerald-300" aria-hidden="true"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </Card>

      <Card title="What it does not guarantee">
        <ul class="space-y-3 text-sm leading-6 text-zinc-300">
          {nonGuarantees.map((item) => (
            <li class="flex gap-3">
              <span class="mt-2 size-1.5 shrink-0 rounded-full bg-zinc-500" aria-hidden="true"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </Card>
    </CardGrid>
  </section>

  <section class="rounded-2xl border border-white/10 bg-zinc-950/75 p-5 ring-1 ring-white/5 sm:p-6">
    <h2 class="mb-4 text-lg font-semibold text-white">Architecture overview</h2>
    <div class="grid gap-6 xl:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
      <div class="space-y-4">
        <div class="overflow-x-auto rounded-xl border border-white/10 bg-black/40 p-4 font-mono text-sm text-zinc-200">
          <div>{architectureLayers.join(' -> ')}</div>
          <div class="mt-2 text-zinc-500">{architecturePersistence.join(' -> ')}</div>
        </div>
      </div>
      <ul class="space-y-3 text-sm leading-6 text-zinc-300">
        {architectureNotes.map((item) => (
          <li class="flex gap-3">
            <span class="mt-2 size-1.5 shrink-0 rounded-full bg-emerald-300" aria-hidden="true"></span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section>
    <CardGrid>
      <Card title="Production-facing features">
        <ul class="space-y-3 text-sm leading-6 text-zinc-300">
          {readinessLinks.map((item) => (
            <li>
              <a class="text-zinc-100 hover:text-emerald-300" href={item.href}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </Card>

      <Card title="Reference surface">
        <ul class="space-y-3 text-sm leading-6 text-zinc-300">
          {compatibilityLinks.map((item) => (
            <li>
              <a class="text-zinc-100 hover:text-emerald-300" href={item.href}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </Card>
    </CardGrid>
  </section>

  <section class="space-y-6 rounded-2xl border border-white/10 bg-zinc-950/75 p-5 ring-1 ring-white/5 sm:p-6">
    <div class="space-y-2">
      <h2 class="text-2xl font-semibold text-white">Getting started in five minutes</h2>
      <p class="text-sm leading-7 text-zinc-300 sm:text-base">
        Start one node with Docker, connect with the TypeScript SDK, and write a durable key.
        Follow the full guide for local clustering, TLS, and non-default credentials.
      </p>
    </div>

    <CardGrid>
      <Card title="Run the server">
        <div class="max-w-full overflow-x-auto rounded-xl border border-white/10 bg-black/50">
          <Code code={landingDockerExample} lang="bash" />
        </div>
      </Card>

      <Card title="Connect with TypeScript">
        <div class="max-w-full overflow-x-auto rounded-xl border border-white/10 bg-black/50">
          <Code code={landingSdkExample} lang="ts" />
        </div>
      </Card>

      <Card title="Use the CLI">
        <div class="space-y-3 text-sm leading-6 text-zinc-300">
          <p>
            <code>vaylix-client</code> opens an interactive REPL.
          </p>
          <div class="max-w-full overflow-x-auto rounded-xl border border-white/10 bg-black/50">
            <Code code={landingCliReplExample} lang="bash" />
          </div>
        </div>
      </Card>
    </CardGrid>

    <div class="flex flex-col gap-3 sm:flex-row">
      <a
        href="/getting-started/"
        class="inline-flex items-center justify-center gap-2 rounded-xl border border-emerald-400/20 bg-emerald-400 px-4 py-3 text-sm font-semibold text-zinc-950 transition hover:bg-emerald-300"
      >
        Open the full getting started guide
      </a>
      <a
        href="/comparison/"
        class="inline-flex items-center justify-center gap-2 rounded-xl border border-white/10 bg-zinc-900 px-4 py-3 text-sm font-semibold text-zinc-100 transition hover:border-emerald-400/30"
      >
        Read the comparison guide
      </a>
    </div>
  </section>
</div>
