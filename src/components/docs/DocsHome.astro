---
import {
  LuArrowRight,
  LuBookOpen,
  LuFileStack,
  LuGitBranch,
} from 'react-icons/lu';
import { FaGithub } from 'react-icons/fa6';
import { boundaries, currentState, homeSections, quickStart } from './data/home';
import DocsMap from './home/DocsMap.astro';
import ProfilePanel from './home/ProfilePanel.astro';
import QuickStartPanel from './home/QuickStartPanel.astro';
import StartHerePanel from './home/StartHerePanel.astro';
import StatusPanel from './home/StatusPanel.astro';
---

<div class="not-prose max-w-full space-y-8 overflow-x-clip">
  <section
    aria-labelledby="home-heading"
    class="max-w-full overflow-hidden rounded-2xl border border-white/10 bg-zinc-950/80 shadow-2xl shadow-black/20 ring-1 ring-emerald-500/10 backdrop-blur"
  >
    <div class="grid max-w-full gap-8 px-5 py-7 sm:px-8 lg:grid-cols-[minmax(0,1.45fr)_minmax(18rem,0.85fr)] lg:px-10 lg:py-10">
      <div class="min-w-0 space-y-6">
        <div class="flex max-w-full flex-wrap items-center gap-3 text-[0.72rem] font-medium uppercase tracking-[0.18em] text-zinc-400 sm:tracking-[0.22em]">
          <span class="rounded-full border border-emerald-500/20 bg-emerald-500/10 px-3 py-1 text-emerald-300">
            Vaylix Docs
          </span>
          <span>Single-node database</span>
          <span aria-hidden="true" class="text-zinc-600">/</span>
          <span>Transport-first runtime</span>
        </div>

        <div class="space-y-4">
          <h1 id="home-heading" class="max-w-4xl text-3xl font-semibold tracking-tight text-white sm:text-5xl">
            Technical documentation for running, integrating, and maintaining Vaylix.
          </h1>
          <p class="max-w-3xl text-base leading-7 text-zinc-300 sm:text-lg">
            Vaylix is a Rust key/value database with a shared transport layer, a Tokio multi-client
            server, segmented encrypted persistence, and default-on authentication. This site
            documents the current implementation in operational terms.
          </p>
        </div>

        <nav aria-label="Primary documentation entry points" class="flex flex-wrap gap-3">
          <a
            href="/getting-started/install-and-build/"
            class="inline-flex items-center gap-2 rounded-xl border border-emerald-400/20 bg-emerald-400 px-4 py-2.5 text-sm font-semibold text-zinc-950 transition hover:bg-emerald-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300"
          >
            Get started
            <LuArrowRight className="size-4" aria-hidden="true" />
          </a>
          <a
            href="/reference/commands/"
            class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-zinc-900 px-4 py-2.5 text-sm font-semibold text-zinc-100 transition hover:border-emerald-400/30 hover:bg-zinc-900/80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300"
          >
            Browse commands
            <LuBookOpen className="size-4" aria-hidden="true" />
          </a>
          <a
            href="https://github.com/vaylix/vaylix"
            class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-transparent px-4 py-2.5 text-sm font-semibold text-zinc-300 transition hover:border-emerald-400/30 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300"
            target="_blank"
            rel="noreferrer"
            aria-label="Open the Vaylix GitHub repository"
          >
            <FaGithub className="size-4" aria-hidden="true" />
            GitHub
          </a>
        </nav>
      </div>

      <ProfilePanel />
    </div>
  </section>

  <section
    aria-labelledby="quickstart-heading"
    class="flex max-w-full flex-col gap-6 xl:flex-row xl:items-stretch"
  >
    <QuickStartPanel code={quickStart} />
    <StartHerePanel />
  </section>

  <DocsMap sections={homeSections} />

  <section aria-labelledby="status-heading" class="flex max-w-full flex-col gap-6 xl:flex-row xl:items-stretch">
    <StatusPanel id="status-heading" title="Current implementation" icon={LuFileStack} items={currentState} />
    <StatusPanel title="Boundaries to keep in mind" icon={LuGitBranch} items={boundaries} tone="zinc" />
  </section>
</div>
